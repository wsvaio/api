{
  "name": "@wsvaio/api",
  "version": "0.0.3-1",
  "description": "一个基于fetch的简易封装",
  "author": "wsvaio <wsvaio@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/wsvaio/api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wsvaio/api.git"
  },
  "keywords": [
    "fetch",
    "api"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup --config rollup.config.ts --configPlugin typescript",
    "dev": "vite ./example",
    "prerelease": "npm run build && npm version prerelease && npm publish",
    "patch": "npm run build && npm version patch && npm publish"
  },
  "dependencies": {
    "@wsvaio/utils": "^0.0.8"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^9.0.2",
    "@types/node": "^18.11.9",
    "@vitejs/plugin-vue": "^3.2.0",
    "rollup": "^3.3.0",
    "rollup-plugin-dts": "^5.0.0",
    "tslib": "^2.4.1",
    "typescript": "^4.8.4",
    "vite": "^3.2.4"
  }
}
